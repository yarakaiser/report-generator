# Copy to .env and fill in for a real POS database. .env is git-ignored.
# If unset, the app defaults to the local isolated test cluster on :5433.

# Read-only connection string to the legacy Calyx POS database.
DATABASE_URL=postgresql://calyx_readonly:readonly_test@127.0.0.1:5433/Earthrise_DB_test

# Log level: trace | debug | info | warn | error (default: debug)
LOG_LEVEL=debug
